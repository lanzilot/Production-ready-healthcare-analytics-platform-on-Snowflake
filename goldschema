1. Create gold schema (if not exists)
CREATE OR REPLACE SCHEMA hospital_db.gold;

2. Date dimension 
CREATE OR REPLACE TABLE hospital_db.gold.dim_date AS
WITH date_range AS (
    SELECT DATEADD(day, seq4(), '2017-01-01') AS date
    FROM TABLE(GENERATOR(rowcount => 3650))
)
SELECT 
    date,
    YEAR(date) AS year,
    MONTH(date) AS month,
    MONTHNAME(date) AS month_name,
    QUARTER(date) AS quarter,
    DAY(date) AS day,
    DAYOFWEEK(date) AS day_of_week,
    DAYNAME(date) AS day_name,
    WEEKOFYEAR(date) AS week_of_year
FROM date_range;

3. Patient dimension 
CREATE OR REPLACE TABLE hospital_db.gold.dim_patient AS
SELECT DISTINCT
    patient_id,
    pin,
    adm_no,
    full_name,
    last_name,
    first_name,
    sex,
    age,
    civil_status,
    address,
    province,
    barangay,
    municipal
FROM hospital_db.silver.patients_clean
WHERE patient_id IS NOT NULL;

4. Doctor dimension 
CREATE OR REPLACE TABLE hospital_db.gold.dim_doctor AS
SELECT DISTINCT
    doctor_id,
    doctor_name,
    specialty
FROM hospital_db.silver.doctors_clean
WHERE doctor_id IS NOT NULL;

5. Item dimension 
CREATE OR REPLACE TABLE hospital_db.gold.dim_item AS
SELECT DISTINCT
    item_id,
    itmcode,
    itmdesc,
    rev_code,
    unit,
    item_cost,
    item_price
FROM hospital_db.silver.item_file_clean
WHERE item_id IS NOT NULL;

6. Fact table – charges (joined to patients via pin and adm_no)
CREATE OR REPLACE TABLE hospital_db.gold.fct_charges AS
SELECT 
    c.charge_id,
    p.patient_id,                     
    NULL AS doctor_id,                
    i.item_id,
    c.charge_date,
    c.quantity,
    c.unit_price,
    c.total_amount,
    c.status,
    c.created_at
FROM hospital_db.silver.charges_clean c
LEFT JOIN hospital_db.silver.patients_clean p 
    ON c.pin = p.pin AND c.adm_no = p.adm_no
LEFT JOIN hospital_db.silver.item_file_clean i 
    ON c.itmcode = i.itmcode
WHERE c.charge_id IS NOT NULL;

7. Monthly revenue view (using fct_charges and dimensions)
CREATE OR REPLACE VIEW hospital_db.gold.monthly_revenue_by_revcode AS
SELECT 
    YEAR(charge_date) AS year,
    MONTH(charge_date) AS month,
    rev_code,
    COUNT(*) AS transaction_count,
    SUM(total_amount) AS total_revenue,
    COUNT(DISTINCT charge_id) AS unique_charges
FROM hospital_db.silver.charges_clean
WHERE rev_code IS NOT NULL
GROUP BY YEAR(charge_date), MONTH(charge_date), rev_code
ORDER BY year DESC, month DESC, total_revenue DESC;

8. Patient 360 view
CREATE OR REPLACE VIEW hospital_db.gold.patient_360 AS
SELECT 
    p.patient_id,
    p.full_name,
    p.sex,
    p.age,
    p.address,
    COUNT(f.charge_id) AS total_visits,
    SUM(f.total_amount) AS total_charges,
    AVG(f.total_amount) AS avg_charge_per_visit,
    MIN(f.charge_date) AS first_visit_date,
    MAX(f.charge_date) AS last_visit_date
FROM hospital_db.gold.dim_patient p
LEFT JOIN hospital_db.gold.fct_charges f ON p.patient_id = f.patient_id
GROUP BY 1,2,3,4,5;

9. Billing anomalies view
CREATE OR REPLACE VIEW hospital_db.gold.billing_anomalies AS
SELECT 
    charge_id,
    patient_id,
    doctor_id,
    charge_date,
    quantity,
    unit_price,
    total_amount,
    status,
    CASE 
        WHEN quantity IS NULL OR quantity <= 0 THEN 'Invalid quantity'
        WHEN unit_price IS NULL OR unit_price <= 0 THEN 'Invalid unit price'
        WHEN total_amount IS NULL OR total_amount <= 0 THEN 'Invalid total amount'
        WHEN quantity * unit_price <> total_amount THEN 'Math mismatch'
        ELSE 'OK'
    END AS anomaly_reason
FROM hospital_db.gold.fct_charges
WHERE quantity IS NULL OR quantity <= 0 
   OR unit_price IS NULL OR unit_price <= 0 
   OR total_amount IS NULL OR total_amount <= 0 
   OR quantity * unit_price <> total_amount;

10. Verification counts
SELECT 'dim_patient' AS object, COUNT(*) FROM hospital_db.gold.dim_patient
UNION ALL SELECT 'dim_doctor', COUNT(*) FROM hospital_db.gold.dim_doctor
UNION ALL SELECT 'dim_item', COUNT(*) FROM hospital_db.gold.dim_item
UNION ALL SELECT 'fct_charges', COUNT(*) FROM hospital_db.gold.fct_charges;
